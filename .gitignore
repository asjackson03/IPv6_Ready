# Byte-compiled / cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Entornos
.env
venv/
.venv/

# Datos generados (se ignoran salvo los .gitkeep)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Base de datos SQLite (regenerable con: python main.py --init-db)
data/*.db

# Base de conocimiento RAG sintética: SÍ se versiona (es parte del código),
# se declara aquí explícitamente para que no la atrape data/processed/*.
!data/sample/knowledge_base/

# Empaquetado
*.egg-info/
dist/
build/

# Sistema operativo / editores
.DS_Store
._*
.vscode/settings.json
*.log

# Claude Code (configuración local, no versionar)
.claude/settings.local.json

# pytest
.pytest_cache/
